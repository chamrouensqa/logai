# Log AI Configuration

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./logai.db
DATABASE_URL_SYNC=sqlite:///./logai.db
# For production with PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://logai:logai@localhost:5432/logai
# DATABASE_URL_SYNC=postgresql://logai:logai@localhost:5432/logai

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch (optional)
ELASTICSEARCH_URL=http://localhost:9200

# AI Provider: openai | anthropic | local
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-5
OPENAI_FALLBACK_MODEL=gpt-4o

# Anthropic (alternative)
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Local LLM (alternative — e.g. Ollama)
# AI_PROVIDER=local
# LOCAL_LLM_URL=http://localhost:11434/api/chat

# Security
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
# JWT session duration in minutes (default in code is 7 days if unset)
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# First admin (created automatically when the users table is empty)
ALPHA_ADMIN_USERNAME=admin
ALPHA_ADMIN_PASSWORD=changeme

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]

# IP reputation (optional — dashboard / alerts / timeline “Check IP”)
# AbuseIPDB: https://www.abuseipdb.com/api
# ABUSEIPDB_API_KEY=
# VirusTotal: https://developers.virustotal.com/reference/ip-info
# VIRUSTOTAL_API_KEY=
